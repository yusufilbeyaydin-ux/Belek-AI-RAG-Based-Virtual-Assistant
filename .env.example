# LLM Provider seçimi (varsayılan: groq)
# Desteklenen değerler: groq | openai | gemini
LLM_PROVIDER=groq

# Groq LLM API (LLM_PROVIDER=groq için zorunlu; analyze_query her zaman Groq kullanır)
GROQ_API_KEY=gsk_...

# OpenAI API (LLM_PROVIDER=openai için gerekli)
# Ücretsiz: yeni hesap kredisi — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini API (LLM_PROVIDER=gemini için gerekli)
# Ücretsiz tier mevcut — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# Firecrawl web scraping API (pipeline için zorunlu)
FIRECRAWL_API_KEY=fc-...

# Qdrant vector database (öncelik: Cloud URL > Local disk > Host:port)
# Seçenek 1 — Cloud (AKTİF, önerilen) ✅
QDRANT_URL=https://xxxx.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Seçenek 2 — Local disk (Docker gerekmez, tek geliştirici için)
# QDRANT_PATH=./qdrant_local

# Seçenek 3 — Docker/uzak sunucu (yalnızca yukarıdakiler boşsa kullanılır)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# CORS — virgülle ayrılmış origin listesi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (belek_chatbot şeması) — opsiyonel etkileşim kaydı
# Tümü girilirse bağlantı kurulur; DB_HOST yorumda kalırsa kayıt devre dışıdır
# DB_HOST=your-host.neon.tech --- (pasif durum)
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
